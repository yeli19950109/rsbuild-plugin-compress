{
  "compilerOptions": {
    "target": "es2020",
    "module": "esnext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "composite": true,
    "erasableSyntaxOnly": true,
    "isolatedDeclarations": true
  },
  "include": [
    "compress.ts"
  ]
}
