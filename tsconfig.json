{
  "compilerOptions": {
    "target": "es2020",
    "module": "esnext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "isolatedDeclarations": true,
    "moduleResolution": "bundler"
  },
  "include": [
    "compress.ts",
    "tsdown.config.ts"
  ]
}
